34 1 16 33
35 4 4 0

# Extension specification for digital output and input triggers:
# id type channel delay (us) duration (us)
extension TRIGGERS 3
1 1 1 0 100

# Extension specification for setting labels:
# id set labelstring
extension LABELSET 1
1 0 LIN
2 0 SLC
3 0 REP
4 1 NOISE
5 0 NOISE
6 1 REV
7 0 REV
8 1 NAV
9 37 LIN
10 0 REF
11 0 SEG
12 0 AVG
13 1 SEG
14 1 AVG
15 1 REF
16 0 NAV
17 1 LIN

# Extension specification for increasing labels:
# id inc labelstring
extension LABELINC 4
1 1 SLC
2 1 LIN
3 2 LIN
4 1 REP

