519      -255276 210 1780 210 10470
520       255276 210 1780 210   0

# Format of ADC events:
# id num dwell delay freqPPM phasePPM freq phase phase_id
# ..  ..    ns    us     ppm  rad/MHz   Hz   rad       ..
[ADC]
1 512 10000 160 0 0 0 3.14159 0
2 512 10000 160 0 0 0 0 0

# Format of extension lists:
# id type ref next_id
# next_id of 0 terminates the list
# Extension list is followed by extension specifications
[EXTENSIONS]
1 1 1 0
2 1 2 0
3 2 1 0
4 2 2 0
5 2 3 0
6 2 4 0
7 3 1 0
8 3 2 0
9 3 3 0

# Extension specification for setting labels:
# id set labelstring
extension LABELSET 1
1 0 LIN
2 0 SLC

# Extension specification for increasing labels:
# id inc labelstring
extension LABELINC 3
1 1 SLC
2 1 LIN
3 1 REP

# Extension specification for soft delays:
# id num offset factor hint
# ..  ..     us     ..   ..
extension DELAYS 2
1 0 -7840 2 TE
2 0 -9320 2 TE
3 0 120000 -1 TE
4 1 -126760 11 TR

# Sequence Shapes
[SHAPES]

